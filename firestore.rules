rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return signedIn() && request.auth.token.role == role;
    }

    function hasAnyRole() {
      return signedIn() && (
        request.auth.token.role == "admin" ||
        request.auth.token.role == "doctor" ||
        request.auth.token.role == "receptionist" ||
        request.auth.token.role == "accountant"
      );
    }

    function canReadClinical() {
      return hasAnyRole();
    }

    // High-sensitivity collections are backend-authoritative only.
    // Clients must use Cloud Functions; direct client writes are denied.
    match /patients/{id} {
      allow read: if canReadClinical();
      allow create, update, delete: if false;
    }

    match /appointments/{id} {
      allow read: if canReadClinical();
      allow create, update, delete: if false;
    }

    match /ledgerEntries/{id} {
      allow read: if hasRole("admin") || hasRole("accountant") || hasRole("doctor");
      allow create, update, delete: if false;
    }

    match /stockMovements/{id} {
      allow read: if hasAnyRole();
      allow create, update, delete: if false;
    }

    match /users/{id} {
      allow read: if signedIn();
      allow update: if hasRole("admin") || (signedIn() && request.auth.uid == id);
      allow create, delete: if hasRole("admin");
    }

    match /clinicSettings/{id} {
      allow read: if hasAnyRole();
      allow create, update, delete: if false;
    }

    match /auditLogs/{id} {
      allow read: if hasRole("admin") || hasRole("accountant");
      allow create, update, delete: if false;
    }

    // Legacy prototype collections are read-only for migration period.
    match /financialRecords/{id} {
      allow read: if hasAnyRole();
      allow create, update, delete: if false;
    }

    match /inventory/{id} {
      allow read: if hasAnyRole();
      allow create, update, delete: if false;
    }

    match /activityLogs/{id} {
      allow read: if hasRole("admin");
      allow create, update, delete: if false;
    }

    // Default deny-all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
