# =========================================================
# LOCAL DEVELOPMENT ENVIRONMENT VARIABLES
# (These mirror the Vercel Production Environment)
# =========================================================

# 🟦 1. Supabase Frontend (Safe for Browser / Client)
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR_PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5c..."
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="pk_..."

# 🟨 2. Supabase Core (SDK / internal access)
SUPABASE_URL="https://[YOUR_PROJECT].supabase.co"
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5c..."

# 🟥 3. Supabase Backend Admin (VERY SENSITIVE - Server Only)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5c..."
SUPABASE_SECRET_KEY="sk_..."
SUPABASE_JWT_SECRET="your-super-secret-jwt-token-with-at-least-32-characters-long"

# 🟩 4. PostgreSQL / Database (direct access layer)
POSTGRES_URL="postgres://default:[PASSWORD]@[HOST]:5432/verceldb"
POSTGRES_HOST="[HOST]"
POSTGRES_USER="default"
POSTGRES_PASSWORD="[PASSWORD]"
POSTGRES_DATABASE="verceldb"

# 🟪 5. Derived / ORM connection layer
# Used by Prisma for pooled connections in Serverless environments
POSTGRES_PRISMA_URL="postgres://default:[PASSWORD]@[HOST]:5432/verceldb?pgbouncer=true&connect_timeout=15"
