{
  "entities": {
    "user": {
      "title": "User",
      "description": "Clinic personnel member profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "clinician", "frontdesk"] },
        "role2": { "type": "string", "enum": ["admin", "clinician", "frontdesk"] },
        "isActive": { "type": "boolean" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "specialty": { "type": "string" },
        "days": { "type": "array" },
        "hours": { "type": "string" }
      },
      "required": ["id", "name", "username", "role", "isActive"]
    },
    "patient": {
      "title": "Patient",
      "description": "Dental patient profile and clinic medical record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "dob": { "type": "string" },
        "gender": { "type": "string" },
        "orthoNotes": { "type": "string" },
        "createdAt": { "type": "string" },
        "fillingRecords": { "type": "array" },
        "extractionRecords": { "type": "array" },
        "prostheticsRecords": { "type": "array" },
        "riskLevel": { "type": "string", "enum": ["Low", "Moderate", "High"] },
        "allergies": { "type": "string" },
        "weight": { "type": "string" },
        "height": { "type": "string" },
        "address": { "type": "string" },
        "occupation": { "type": "string" }
      },
      "required": ["id", "name", "phone", "dob", "gender", "createdAt"]
    },
    "appointment": {
      "title": "Appointment",
      "description": "Scheduled or checked-in clinic appointment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "patientPhone": { "type": "string" },
        "doctorName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "procedureType": { "type": "string" },
        "status": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "patientId", "patientName", "doctorName", "date", "time", "procedureType", "status"]
    },
    "financialRecord": {
      "title": "Financial Record",
      "description": "Payment ledger receipts or operational cost debits",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "procedureName": { "type": "string" },
        "totalCost": { "type": "number" },
        "paidAmount": { "type": "number" },
        "remainingAmount": { "type": "number" },
        "paymentStatus": { "type": "string" },
        "date": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "receiptNo": { "type": "string" },
        "notes": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "expenseCategory": { "type": "string" },
        "expenseType": { "type": "string" },
        "periodType": { "type": "string" }
      },
      "required": ["id", "patientId", "patientName", "procedureName", "totalCost", "paidAmount", "remainingAmount", "paymentStatus", "date", "receiptNo"]
    },
    "inventoryItem": {
      "title": "Inventory Item",
      "description": "Supplies and materials batch log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "minQty": { "type": "number" },
        "expiryDate": { "type": "string" },
        "batchNo": { "type": "string" },
        "suggestedFirst": { "type": "boolean" },
        "pricePerUnit": { "type": "number" }
      },
      "required": ["id", "name", "quantity", "unit", "minQty", "expiryDate", "batchNo"]
    },
    "activityLog": {
      "title": "Activity Log",
      "description": "Chronological audit-trail action registration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "user": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["id", "timestamp", "user", "action", "details"]
    },
    "clinicSettings": {
      "title": "Clinic Settings",
      "description": "Branding elements and business contact references",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "social": { "type": "string" }
      },
      "required": ["name", "logo", "address", "phone"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "Direct profiles for authorised dental personnel"
    },
    "/patients/{patientId}": {
      "schema": "patient",
      "description": "Workstation patient data blocks"
    },
    "/appointments/{appointmentId}": {
      "schema": "appointment",
      "description": "Patient clinic booking and treatment logs"
    },
    "/financialRecords/{recordId}": {
      "schema": "financialRecord",
      "description": "Income and expenditures billing ledger"
    },
    "/inventory/{itemId}": {
      "schema": "inventoryItem",
      "description": "Practitioner supply cabinet control log"
    },
    "/activityLogs/{logId}": {
      "schema": "activityLog",
      "description": "Action log audit trail"
    },
    "/clinicSettings/{settingsId}": {
      "schema": "clinicSettings",
      "description": "Global settings parameters"
    }
  }
}
